/span><br><span class="line">application-<span class="keyword">label</span><span class="bash">:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-en:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-in:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-zh_HK:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-zh_MO:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-ja_JP:<span class="string">'LoginDemo'</span></span></span><br><span class="line"><span class="bash">application-label-zh_TW:<span class="string">'LoginDemo'</span></span></span><br></pre></td></tr></table></figure>]]></content>
    
